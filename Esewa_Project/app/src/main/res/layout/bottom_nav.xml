<?xml version="1.0" encoding="UTF-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/navItemShop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="10dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/iconShop"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/nav_shop"
            android:contentDescription="@string/shop_icon"
            app:tint="#28AD17" />

        <TextView
            android:id="@+id/textShop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/shop"
            android:textColor="#28AD17"
            android:textStyle="bold"
            android:visibility="visible"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/navItemCart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="10dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/iconCart"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/nav_cart"
            android:contentDescription="@string/cart_icon"
            app:tint="#28AD17" />

        <TextView
            android:id="@+id/textCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/cart"
            android:textColor="#28AD17"
            android:textStyle="bold"
            android:visibility="visible"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/navItemHeart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="10dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/iconHeart"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/heart"
            android:contentDescription="@string/heart_icon"
            app:tint="#28AD17" />

        <TextView
            android:id="@+id/textHeart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/heart"
            android:textColor="#28AD17"
            android:textStyle="bold"
            android:visibility="visible"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/navItemMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav"
        android:clickable="true"
        android:focusable="true"
        android:paddingVertical="10dp"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/iconMore"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/nav_more"
            android:contentDescription="@string/more_icon"
            app:tint="#28AD17" />

        <TextView
            android:id="@+id/textMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/more"
            android:textColor="#28AD17"
            android:textStyle="bold"
            android:visibility="visible"/>

    </LinearLayout>



</LinearLayout>